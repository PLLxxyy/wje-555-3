# Docker Compose 项目名，固定后可在中文目录下稳定启动
COMPOSE_PROJECT_NAME=wjerenthub

# MySQL 8.0
MYSQL_DATABASE=renthub
MYSQL_USER=renthub
MYSQL_PASSWORD=change_me
MYSQL_ROOT_PASSWORD=change_root_me

# Django
DJANGO_SECRET_KEY=change_this_secret
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
DB_ENGINE=mysql
DB_HOST=db
DB_PORT=3306
DB_NAME=renthub
DB_USER=renthub
DB_PASSWORD=change_me

# Frontend
VITE_API_BASE_URL=/api

